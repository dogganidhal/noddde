{
  "name": "@noddde/drizzle",
  "version": "0.0.0",
  "description": "Drizzle ORM persistence adapter for noddde",
  "license": "MIT",
  "author": "Nidhal Dogga",
  "homepage": "https://noddde.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/dogganidhal/noddde",
    "directory": "packages/adapters/drizzle"
  },
  "bugs": {
    "url": "https://github.com/dogganidhal/noddde/issues"
  },
  "keywords": [
    "ddd",
    "cqrs",
    "event-sourcing",
    "drizzle",
    "typescript",
    "persistence"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./sqlite": {
      "types": "./dist/sqlite/schema.d.ts",
      "default": "./dist/sqlite/schema.js"
    },
    "./pg": {
      "types": "./dist/pg/schema.d.ts",
      "default": "./dist/pg/schema.js"
    },
    "./mysql": {
      "types": "./dist/mysql/schema.d.ts",
      "default": "./dist/mysql/schema.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noddde/core": "0.0.0"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.30.0"
  },
  "devDependencies": {
    "@noddde/typescript-config": "0.0.0",
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.30.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}
